rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin helper ───────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        '30copallock@pulaskischools.org',
        'coltenboop@gmail.com',
        'ohioshared@gmail.com'
      ];
    }

    // ── Users ──────────────────────────────────────────────────────────────
    // Any signed-in user can read profiles (needed for search + DM avatars).
    // Owner can write their own document. Admins can update any user (for banning).
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if (request.auth != null && request.auth.uid == userId)
                    || isAdmin();
    }

    // ── Messages ───────────────────────────────────────────────────────────
    // Any signed-in user can read.
    // Only the actual sender can create a message.
    // Sender can delete their own message; admins can delete any message.
    // Any user can delete messages older than 7 days (for client-side pruning).
    match /messages/{msgId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.senderId;
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.senderId
                        || isAdmin()
                        || resource.data.timestamp < request.time - duration.value(7, 'd'));
    }

    // ── DM Chats ───────────────────────────────────────────────────────────
    // Only participants can read or write the chat metadata document.
    match /chats/{chatId} {
      allow read:   if request.auth != null
                    && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;
    }

    // ── Restrictions ───────────────────────────────────────────────────────
    // Any signed-in user can read their own restriction (to check on send).
    // Only admins can create or update restrictions. User or admin can delete.
    match /restrictions/{userId} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write:  if isAdmin();
      allow delete: if isAdmin() || request.auth.uid == userId;
    }

  }
}

